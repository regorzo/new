/* Title overlay */
.about-title {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.35); /* dark overlay for readability */
}

.about-title h1 {
    color: white;
    font-size: 42px;
    font-weight: 700;
    margin: 0;
}


.About-Header {
    max-width: 800px;      /* controls how compressed it is */
    margin: 60px auto;    /* centers the block */
    text-align: left;     /* left-align text inside */
    line-height: 1;
    font-size: 40px;
}


.About-Flex-Section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 10px auto 30px;
    padding: 0 150px;   /* matches your H1 horizontal feel */
    gap: 60px;
}
.About-Flex-Text h2 {
    max-width: 300px;
    margin: 0 0 20px 0;
    text-align: left;
    line-height: 1.1;
    font-size: 32px;   /* slightly smaller than main H1 */
}

.About-Flex-Text p {
    max-width: 800px;
    font-size: 16px;
    line-height: 1.6;
    color: #070000;
}

.About-Flex-Image img {
    max-width: 350px;
    width: 100%;
    border-radius: 12px;
    object-fit: cover;
}


.Team-Grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2 columns */
    gap: 80px;                             /* space between people */
    max-width: 900px;
    margin: 40px auto;
    padding: 0 150px;
}

.Team-Card h3 {
    font-size: 20px;
    margin-bottom: 5px;
}

.Team-Card .role {
    font-size: 14px;
    margin-bottom: 12px;
    color: #333;
}

.Team-Card .contact {
    font-size: 14px;
    margin: 4px 0;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #0056b3; /* blue like your icons */   
}


.Team-Section-Title {
    max-width: 900px;
    margin: 80px auto 30px;
    padding: 0 150px;
    font-size: 36px;
    font-weight: 600;
    text-align: left;
    color: black;
}


.Team-Section-Title::after {
    content: "";
    display: block;
    width: 240px;
    height: 4px;
    background: #000;
    margin-top: 12px;
}
